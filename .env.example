# Copy to .env.local for local dev. Set the same keys in Vercel → Settings → Environment Variables.

# --- Supabase (required for auth, checkout, organizer accounts) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site origin (no trailing slash).
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HMAC secret for organizer session cookies (required in production).
# Generate: openssl rand -hex 32
ORGANIZER_SESSION_SECRET=

# HMAC secret for platform admin session cookies (required in production).
# Generate: openssl rand -hex 32 (use a different value than ORGANIZER_SESSION_SECRET)
ADMIN_SESSION_SECRET=

# Local-only organizer gate when Supabase organizer accounts are not set up
ORGANIZER_DEV_PASSWORD=

# --- Payfast (optional — without these, paid tiers use pay-at-door) ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# --- Contact & social (optional) ---
NEXT_PUBLIC_CONTACT_EMAIL=hello@spotra.co.za
NEXT_PUBLIC_SUPPORT_EMAIL=support@spotra.co.za
NEXT_PUBLIC_LEGAL_EMAIL=legal@spotra.co.za
NEXT_PUBLIC_POPIA_EMAIL=privacy@spotra.co.za
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_WHATSAPP_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_FACEBOOK_URL=
